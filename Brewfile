# Core CLI tools
brew "bat"       # cat with syntax highlighting
brew "fd"        # fast find; fzf file backend (see .zshrc)
brew "fzf"       # fuzzy finder
brew "gh"        # github cli (prweb func)
brew "jq"        # json processor
brew "neovim"    # editor (vim -> nvim)
brew "ripgrep"   # fast grep
brew "starship"  # shell prompt (see .zshrc)
brew "tree"      # dir tree; fzf dir preview (see .zshrc)

# Go toolchain (GOPATH/GOROOT configured in .zshrc)
brew "go"

# Terminal font (Nerd Font glyphs for starship)
cask "font-meslo-lg-nerd-font"
